{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM"],
    "types": ["node"]
  },
  "include": ["*.ts", "src/**/*.ts"],
  // Test files use `bun:test` (untyped here) and run under `bun test`, not tsc — exclude them
  // from the worker/CLI compile, mirroring packages/api's tsconfig.
  "exclude": ["*.test.ts"]
}
